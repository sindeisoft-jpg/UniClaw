"use client";

import { useCallback, useEffect, useState, useMemo } from "react";
import { useGateway } from "@/contexts/gateway-context";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Card } from "@/components/ui/card";
import { 
  RefreshCw, 
  AlertCircle, 
  Save,
  Search,
  Settings,
  Database,
  Server,
  Users,
  Key,
  Globe,
  Bell,
  Shield,
  Code,
  Eye,
  EyeOff,
  ChevronDown,
  ChevronRight,
  CheckCircle,
  XCircle,
  Info
} from "lucide-react";

type ConfigSnapshot = {
  config?: Record<string, any>;
  baseHash?: string;
  sections?: Array<{
    id: string;
    label: string;
    icon?: string;
    description?: string;
    fields?: Array<{
      key: string;
      label: string;
      type: string;
      description?: string;
      defaultValue?: any;
      options?: Array<{ value: string; label: string }>;
    }>;
  }>;
};

type ConfigSection = {
  id: string;
  label: string;
  icon: React.ElementType;
  color: string;
  description: string;
  fields: string[];
};

const CONFIG_SECTIONS: ConfigSection[] = [
  {
    id: "gateway",
    label: "网关",
    icon: Server,
    color: "text-blue-600",
    description: "网关连接和网络设置",
    fields: ["gateway.url", "gateway.port", "gateway.mode", "gateway.auth", "gateway.controlUi"]
  },
  {
    id: "agents",
    label: "智能体",
    icon: Users,
    color: "text-green-600",
    description: "智能体配置和身份",
    fields: ["agents.list", "agents.default", "agents.identity", "agents.workspace"]
  },
  {
    id: "auth",
    label: "认证",
    icon: Key,
    color: "text-amber-600",
    description: "API密钥和认证配置",
    fields: ["auth.profiles", "auth.order", "auth.default", "auth.providers"]
  },
  {
    id: "channels",
    label: "渠道",
    icon: Globe,
    color: "text-purple-600",
    description: "消息渠道配置",
    fields: ["channels.whatsapp", "channels.telegram", "channels.discord", "channels.signal", "channels.imessage"]
  },
  {
    id: "cron",
    label: "定时任务",
    icon: Bell,
    color: "text-pink-600",
    description: "定时任务和调度",
    fields: ["cron.enabled", "cron.jobs", "cron.schedule", "cron.timezone"]
  },
  {
    id: "security",
    label: "安全",
    icon: Shield,
    color: "text-red-600",
    description: "安全策略和访问控制",
    fields: ["security.allowlist", "security.rateLimit", "security.cors", "security.audit"]
  },
  {
    id: "storage",
    label: "存储",
    icon: Database,
    color: "text-cyan-600",
    description: "数据存储和持久化",
    fields: ["storage.path", "storage.backup", "storage.retention", "storage.encryption"]
  },
  {
    id: "advanced",
    label: "高级",
    icon: Code,
    color: "text-gray-600",
    description: "高级配置和调试",
    fields: ["debug.enabled", "log.level", "metrics.enabled", "experimental.features"]
  }
];

export function ConfigSection() {
  const { client, connected } = useGateway();
  const [loading, setLoading] = useState(false);
  const [config, setConfig] = useState<Record<string, any> | null>(null);
  const [raw, setRaw] = useState("{}");
  const [baseHash, setBaseHash] = useState<string | null>(null);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [mode, setMode] = useState<"form" | "raw">("form");
  const [search, setSearch] = useState("");
  const [expandedSections, setExpandedSections] = useState<Set<string>>(new Set(["gateway", "agents"]));
  const [showRaw, setShowRaw] = useState(false);

  const load = useCallback(async () => {
    if (!client || !connected) return;
    setLoading(true);
    setError(null);
    try {
      const res = await client.request<ConfigSnapshot>("config.get", {});
      setConfig(res?.config ?? null);
      setBaseHash(res?.baseHash ?? null);
      setRaw(
        res?.config != null
          ? JSON.stringify(res.config as object, null, 2)
          : "{}"
      );
    } catch (e) {
      setError(String(e));
    } finally {
      setLoading(false);
    }
  }, [client, connected]);

  useEffect(() => {
    if (connected) void load();
  }, [connected, load]);

  async function handleSave() {
    if (!client || !connected || saving) return;
    let parsed: unknown;
    try {
      parsed = JSON.parse(raw);
    } catch {
      setError("JSON 格式无效");
      return;
    }
    setSaving(true);
    setError(null);
    try {
      await client.request("config.set", { raw: JSON.stringify(parsed), baseHash: baseHash ?? undefined });
      await load();
    } catch (e) {
      setError(String(e));
    } finally {
      setSaving(false);
    }
  }

  const toggleSection = (sectionId: string) => {
    const newExpanded = new Set(expandedSections);
    if (newExpanded.has(sectionId)) {
      newExpanded.delete(sectionId);
    } else {
      newExpanded.add(sectionId);
    }
    setExpandedSections(newExpanded);
  };

  const filteredSections = useMemo(() => {
    if (!search.trim()) return CONFIG_SECTIONS;
    
    const searchLower = search.toLowerCase();
    return CONFIG_SECTIONS.filter(section => 
      section.label.toLowerCase().includes(searchLower) ||
      section.description.toLowerCase().includes(searchLower) ||
      section.fields.some(field => field.toLowerCase().includes(searchLower))
    );
  }, [search]);

  const getFieldValue = (fieldPath: string): any => {
    if (!config) return undefined;
    
    const parts = fieldPath.split('.');
    let current: any = config;
    for (const part of parts) {
      if (current && typeof current === 'object' && part in current) {
        current = current[part];
      } else {
        return undefined;
      }
    }
    return current;
  };

const renderField = (fieldPath: string) => {
    const value = getFieldValue(fieldPath);
    const isObject = value && typeof value === 'object';
    
    return (
      <div key={fieldPath} className="space-y-2">
        <div className="flex items-center justify-between">
          <div className="font-mono text-sm">{fieldPath}</div>
          <div className="text-xs text-muted-foreground">
            {isObject ? "对象" : typeof value}
          </div>
        </div>
        <div className="rounded border border-border bg-muted/30 p-3">
          {isObject ? (
            <pre className="text-xs overflow-auto max-h-40">
              {JSON.stringify(value, null, 2)}
            </pre>
          ) : (
            <div className="font-mono text-sm">
              {value === null ? "null" : String(value)}
            </div>
          )}
        </div>
      </div>
    );
  };

  if (!connected) {
    return (
      <div className="rounded-lg border border-border bg-card p-8 text-center">
        <Settings className="mx-auto h-12 w-12 text-muted-foreground" />
        <h3 className="mt-4 text-lg font-medium">未连接网关</h3>
        <p className="mt-2 text-sm text-muted-foreground">
          请先连接网关后在概览中配置连接。
        </p>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-2xl font-bold">配置管理</h2>
          <p className="text-sm text-muted-foreground">
            管理网关配置和设置
          </p>
        </div>
        <div className="flex items-center gap-3">
          <Button onClick={load} disabled={loading} variant="outline">
            <RefreshCw className={`h-4 w-4 mr-2 ${loading ? "animate-spin" : ""}`} />
            {loading ? "加载中…" : "刷新"}
          </Button>
          <Button 
            onClick={() => setMode(mode === "form" ? "raw" : "form")}
            variant={mode === "form" ? "outline" : "default"}
          >
            {mode === "form" ? "切换到原始 JSON" : "切换到表单"}
          </Button>
        </div>
      </div>

      {error && (
        <div className="rounded-lg border border-red-200 bg-red-50 p-4 dark:border-red-900 dark:bg-red-950">
          <div className="flex items-start gap-2">
            <AlertCircle className="h-5 w-5 text-red-600 dark:text-red-400 mt-0.5" />
            <div className="text-sm text-red-800 dark:text-red-300">{error}</div>
          </div>
        </div>
      )}

      {mode === "form" ? (
        <>
          {/* 搜索栏 */}
          <div className="relative">
            <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground" />
            <Input
              type="search"
              placeholder="搜索配置项..."
              value={search}
              onChange={(e) => setSearch(e.target.value)}
              className="pl-10"
            />
          </div>

          {/* 配置分节 */}
          <div className="space-y-4">
            {filteredSections.map((section) => {
              const Icon = section.icon;
              const isExpanded = expandedSections.has(section.id);
              const sectionFields = section.fields.filter(field => 
                !search || field.toLowerCase().includes(search.toLowerCase())
              );

              if (search && sectionFields.length === 0) return null;

              return (
                <Card key={section.id} className="overflow-hidden">
                  <div 
                    className="flex items-center justify-between p-4 cursor-pointer hover:bg-muted/50"
                    onClick={() => toggleSection(section.id)}
                  >
                    <div className="flex items-center gap-3">
                      <div className={`rounded-lg p-2 ${section.color.replace("text-", "bg-")}/10`}>
                        <Icon className={`h-5 w-5 ${section.color}`} />
                      </div>
                      <div>
                        <h3 className="font-medium">{section.label}</h3>
                        <p className="text-sm text-muted-foreground">{section.description}</p>
                      </div>
                    </div>
                    <div className="flex items-center gap-2">
                      <span className="text-xs text-muted-foreground">
                        {sectionFields.length} 项
                      </span>
                      {isExpanded ? (
                        <ChevronDown className="h-4 w-4 text-muted-foreground" />
                      ) : (
                        <ChevronRight className="h-4 w-4 text-muted-foreground" />
                      )}
                    </div>
                  </div>
                  
                  {isExpanded && sectionFields.length > 0 && (
                    <div className="border-t p-4 space-y-4">
                      {sectionFields.map(renderField)}
                    </div>
                  )}
                </Card>
              );
            })}

            {filteredSections.length === 0 && (
              <div className="rounded-lg border border-border bg-card p-8 text-center">
                <Search className="mx-auto h-12 w-12 text-muted-foreground" />
                <h3 className="mt-4 text-lg font-medium">未找到匹配项</h3>
                <p className="mt-2 text-sm text-muted-foreground">
                  没有找到与 "{search}" 匹配的配置项
                </p>
              </div>
            )}
          </div>
        </>
      ) : (
        /* 原始 JSON 编辑器 */
        <div className="space-y-4">
          <div className="flex items-center justify-between">
            <div className="text-sm text-muted-foreground">
              编辑原始 JSON 配置
            </div>
            <Button
              variant="outline"
              size="sm"
              onClick={() => setShowRaw(!showRaw)}
            >
              {showRaw ? (
                <>
                  <EyeOff className="h-4 w-4 mr-2" />
                  隐藏敏感信息
                </>
              ) : (
                <>
                  <Eye className="h-4 w-4 mr-2" />
                  显示敏感信息
                </>
              )}
            </Button>
          </div>
          
          <textarea
            value={raw}
            onChange={(e) => setRaw(e.target.value)}
            className="h-96 w-full rounded-md border border-input bg-background p-3 font-mono text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
            spellCheck={false}
          />
          
          <div className="flex items-center justify-between">
            <div className="text-sm text-muted-foreground">
              {baseHash && `配置哈希: ${baseHash.slice(0, 8)}...`}
            </div>
            <div className="flex gap-3">
              <Button
                variant="outline"
                onClick={() => {
                  try {
                    const parsed = JSON.parse(raw);
                    setRaw(JSON.stringify(parsed, null, 2));
                  } catch {
                    setError("JSON 格式无效，无法格式化");
                  }
                }}
              >
                格式化
              </Button>
              <Button onClick={handleSave} disabled={saving || loading}>
                <Save className="h-4 w-4 mr-2" />
                {saving ? "保存中…" : "保存配置"}
              </Button>
            </div>
          </div>
        </>
      )}
    </div>
  );
}
